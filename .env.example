# ============================================
# AZURE OPENAI
# ============================================
AZURE_OPENAI_ENDPOINT=https://your-endpoint.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Global fallback model/pricing (used when stage-specific keys are missing)
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_MODEL_INPUT_PRICE_PER_1M=5.00
AZURE_MODEL_OUTPUT_PRICE_PER_1M=20.00

# Optional: model-level pricing (applies to all stages using that model)
# Key format: MODEL_<MODEL_NAME_NORMALIZED>_INPUT/OUTPUT_PRICE
# Example: gpt-4o-vision -> MODEL_GPT_4O_VISION_INPUT_PRICE
MODEL_GPT_4O_VISION_INPUT_PRICE=5.00
MODEL_GPT_4O_VISION_OUTPUT_PRICE=20.00
MODEL_O4_MINI_INPUT_PRICE=1.10
MODEL_O4_MINI_OUTPUT_PRICE=4.40

# Pricing priority used by code:
# 1) STAGE_N_INPUT/OUTPUT_PRICE (if set)
# 2) MODEL_<MODEL_NAME>_INPUT/OUTPUT_PRICE (if set)
# 3) AZURE_MODEL_INPUT/OUTPUT_PRICE_PER_1M (global fallback)

# ============================================
# PER-STAGE MODEL CONFIGURATION
# ============================================
# Supported stages in code:
# 0 = classification/layout/rotation (pre-stages)
# 1 = basic info extraction (part#, drawing#)
# 2 = processes extraction (including item-details extraction)
# 3 = notes extraction
# 4 = geometric area extraction
# 5 = validation/fallback from notes + email quantity extraction
# 6 = parts list (PL) extraction
# 7 = email text quantity extraction
# 8 = quote/order/invoice item-details extraction

# Stage 0
STAGE_0_MODEL=gpt-4o-mini
STAGE_0_INPUT_PRICE=0.15
STAGE_0_OUTPUT_PRICE=0.60
STAGE_0_TEMPERATURE=0
STAGE_0_MAX_TOKENS=300

# Stage 1
STAGE_1_MODEL=gpt-5.4
STAGE_1_INPUT_PRICE=10.00
STAGE_1_OUTPUT_PRICE=40.00
STAGE_1_TEMPERATURE=0
STAGE_1_MAX_TOKENS=1000

# Stage 2
STAGE_2_MODEL=gpt-4o
STAGE_2_INPUT_PRICE=5.00
STAGE_2_OUTPUT_PRICE=20.00
STAGE_2_TEMPERATURE=0
STAGE_2_MAX_TOKENS=1500

# Stage 3
STAGE_3_MODEL=gpt-4o
STAGE_3_INPUT_PRICE=5.00
STAGE_3_OUTPUT_PRICE=20.00
STAGE_3_TEMPERATURE=0
STAGE_3_MAX_TOKENS=1200

# Stage 4
STAGE_4_MODEL=gpt-4o-mini
STAGE_4_INPUT_PRICE=0.15
STAGE_4_OUTPUT_PRICE=0.60
STAGE_4_TEMPERATURE=0
STAGE_4_MAX_TOKENS=800

# Stage 5
STAGE_5_MODEL=gpt-4o
STAGE_5_INPUT_PRICE=5.00
STAGE_5_OUTPUT_PRICE=20.00
STAGE_5_TEMPERATURE=0
STAGE_5_MAX_TOKENS=400

# Stage 6
STAGE_6_MODEL=gpt-4o-mini
STAGE_6_INPUT_PRICE=0.15
STAGE_6_OUTPUT_PRICE=0.60
STAGE_6_TEMPERATURE=0.2
STAGE_6_MAX_TOKENS=2000

# Stage 7 (Email quantities) — o4-mini for smart quantity extraction
STAGE_7_MODEL=o4-mini
STAGE_7_INPUT_PRICE=1.10
STAGE_7_OUTPUT_PRICE=4.40
STAGE_7_TEMPERATURE=0
STAGE_7_MAX_TOKENS=800

# Stage 8 (Quote/Order item details)
STAGE_8_MODEL=gpt-4o
STAGE_8_INPUT_PRICE=5.00
STAGE_8_OUTPUT_PRICE=20.00
STAGE_8_TEMPERATURE=0
STAGE_8_MAX_TOKENS=1500

# Stage 9 (Smart description merge) — text-only
STAGE_9_MODEL=o4-mini
STAGE_9_INPUT_PRICE=1.10
STAGE_9_OUTPUT_PRICE=4.40
STAGE_9_TEMPERATURE=0
STAGE_9_MAX_TOKENS=32000

# ============================================
# MODEL-SPECIFIC ENDPOINTS
# (for models deployed on a different Azure resource)
# Key format: MODEL_<NORMALIZED_NAME>_ENDPOINT / _API_KEY / _API_VERSION
# ============================================
# MODEL_GPT_5_4_ENDPOINT=https://your-gpt54-resource.openai.azure.com
# MODEL_GPT_5_4_API_KEY=your-api-key
# MODEL_GPT_5_4_API_VERSION=2024-12-11-preview
# MODEL_GPT_5_4_INPUT_PRICE=2.50
# MODEL_GPT_5_4_OUTPUT_PRICE=15.00
# MODEL_GPT_5_4_IS_REASONING=true

# MODEL_GPT_5_2_ENDPOINT=https://your-gpt52-resource.openai.azure.com
# MODEL_GPT_5_2_API_KEY=your-api-key
# MODEL_GPT_5_2_API_VERSION=2024-12-11-preview
# MODEL_GPT_5_2_INPUT_PRICE=1.75
# MODEL_GPT_5_2_OUTPUT_PRICE=14.00
# MODEL_GPT_5_2_IS_REASONING=true

# Optional
USD_TO_ILS_RATE=3.7
AI_DRAW_DEBUG=false

# IAI-specific: Stage 1B top-red header OCR fallback (not a GPT stage)
IAI_TOP_RED_FALLBACK_ENABLED=true

# ============================================
# TESSERACT OCR
# ============================================
# Windows default path (update if installed elsewhere):
TESSERACT_PATH=C:/Program Files/Tesseract-OCR/tesseract.exe
# Languages: eng for English, heb for Hebrew, ara for Arabic
TESSERACT_LANGS=eng+heb

# ============================================
# MICROSOFT GRAPH API (for email automation)
# ============================================
# EMAIL_METHOD=GRAPH_API
# GRAPH_TENANT_ID=your-tenant-id
# GRAPH_CLIENT_ID=your-client-id
# GRAPH_CLIENT_SECRET=your-client-secret
# SHARED_MAILBOX_NAME=quotes@yourcompany.com
# LAST_RECIPIENT_EMAIL=user@yourcompany.com
